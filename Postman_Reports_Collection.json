      "item": [
        {
          "name": "1. Platos Más Vendidos",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/Restaurante/v1/reports/top-selling-plates?limit=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "Restaurante",
                "v1",
                "reports",
                "top-selling-plates"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "restaurantId",
                  "value": "",
                  "disabled": true
                }
              ]
            },
            "description": "Obtiene los platos más vendidos del sistema"
          },
          "response": []
        },
        {
