{
  "info": {
    "_postman_id": "reports-api-collection",
    "name": "Sistema Restaurante - Reports API",
    "description": "Colección de endpoints para probar la API de Reportes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
